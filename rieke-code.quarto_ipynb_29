    "\n",
    "df_combined['conditionLength_f'] = df_combined['conditionlength'].astype(str)\n",
    "\n",
    "def main_effect_table(data, outcome_column):\n",
    "  model_data = data[['conditionlength', 'conditiontype', outcome_column]].dropna().copy()\n",
    "  model_data['conditionlength'] = model_data['conditionlength'].astype(str)\n",
    "  model_data['conditiontype'] = model_data['conditiontype'].astype(str)\n",
    "  model_data[outcome_column] = pd.to_numeric(model_data[outcome_column], errors='coerce')\n",
    "  model_data = model_data.dropna(subset=[outcome_column])\n",
    "  model_data[outcome_column] = model_data[outcome_column].astype(float)\n",
    "\n",
    "  model = smf.ols(f\"{outcome_column} ~ C(conditionlength) * C(conditiontype)\", data=model_data).fit()\n",
    "  anova_df = anova_lm(model, typ=2).reset_index()\n",
    "  anova_df = anova_df[anova_df['index'].isin([\n",
    "    'C(conditionlength)',\n",
    "    'C(conditiontype)',\n",
    "    'C(conditionlength):C(conditiontype)'\n",
    "  ])].copy()\n",
    "  anova_df['Effect'] = anova_df['index'].replace({\n",
    "    'C(conditionlength)': 'Slide length',\n",
    "    'C(conditiontype)': 'Format',\n",
    "    'C(conditionlength):C(conditiontype)': 'Length x format'\n",
    "  })\n",
    "  anova_df['Significant'] = np.where(anova_df['PR(>F)'] < 0.05, 'Yes', 'No')\n",
    "  return anova_df[['Effect', 'F', 'PR(>F)', 'Significant']].rename(columns={'PR(>F)': 'p_value'})\n",
    "\n",
    "def outcome_plot(data, outcome_column, outcome_label, y_breaks=None, y_labels=None, y_limits=None):\n",
    "  p = (\n",
    "    ggplot(data, aes(x='conditionLength_f', y=outcome_column, fill='conditiontype'))\n",
    "    + geom_violin(position=position_dodge(width=0.75), alpha=0.65, trim=False)\n",
    "    + geom_jitter(position=position_jitterdodge(jitter_width=0.12, dodge_width=0.75), alpha=0.35, size=1)\n",
    "    + theme_light()\n",
    "    + labs(x='Slide length', y=outcome_label, fill='Format')\n",
    "  )\n",
    "  if y_breaks is not None:\n",
    "    if y_labels is None:\n",
    "      if y_limits is None:\n",
    "        p = p + scale_y_continuous(breaks=y_breaks)\n",
    "      else:\n",
    "        p = p + scale_y_continuous(breaks=y_breaks, limits=y_limits)\n",
    "    else:\n",
    "      if y_limits is None:\n",
    "        p = p + scale_y_continuous(breaks=y_breaks, labels=y_labels)\n",
    "      else:\n",
    "        p = p + scale_y_continuous(breaks=y_breaks, labels=y_labels, limits=y_limits)\n",
    "  return p\n",
    "\n",
    "def outcome_trend_plot(data, outcome_column, outcome_label, y_breaks=None, y_labels=None, y_limits=None):\n",
    "  trend_data = (\n",
    "    data[['conditionlength', 'conditiontype', outcome_column]]\n",
    "    .dropna()\n",
    "    .copy()\n",
    "  )\n",
    "  trend_data[outcome_column] = pd.to_numeric(trend_data[outcome_column], errors='coerce')\n",
    "  trend_data = trend_data.dropna(subset=[outcome_column])\n",
    "  trend_data['conditionlength_num'] = pd.to_numeric(trend_data['conditionlength'], errors='coerce')\n",
    "  trend_data = trend_data.dropna(subset=['conditionlength_num'])\n",
    "\n",
    "  trend_summary = (\n",
    "    trend_data\n",
    "    .groupby(['conditionlength_num', 'conditiontype'], as_index=False)[outcome_column]\n",
    "    .mean()\n",
    "  )\n",
    "\n",
    "  p = (\n",
    "    ggplot(trend_summary, aes(x='conditionlength_num', y=outcome_column, color='conditiontype', group='conditiontype'))\n",
    "    + geom_line(size=1)\n",
    "    + geom_point(size=2)\n",
    "    + theme_light()\n",
    "    + scale_x_continuous(breaks=[30, 50, 100])\n",
    "    + labs(x='Slide length (numeric)', y=outcome_label, color='Format')\n",
    "  )\n",
    "\n",
    "  if y_breaks is not None:\n",
    "    if y_labels is None:\n",
    "      if y_limits is None:\n",
    "        p = p + scale_y_continuous(breaks=y_breaks)\n",
    "      else:\n",
    "        p = p + scale_y_continuous(breaks=y_breaks, limits=y_limits)\n",
    "    else:\n",
    "      if y_limits is None:\n",
    "        p = p + scale_y_continuous(breaks=y_breaks, labels=y_labels)\n",
    "      else:\n",
    "        p = p + scale_y_continuous(breaks=y_breaks, labels=y_labels, limits=y_limits)\n",
    "\n",
    "  return p\n",
    "\n",
    "def numeric_trend_takeaway(data, outcome_column, positive_text, negative_text):\n",
