    "#| code-fold: true\n",
    "\n",
    "# Function to read CSV and add condition column\n",
    "def read_csv_with_condition(file_path):\n",
    "    raw = pd.read_csv(file_path, header=None, nrows=2)\n",
    "    row0 = raw.iloc[0].tolist()\n",
    "    row1 = raw.iloc[1].tolist()\n",
    "\n",
    "    df = pd.read_csv(file_path, header=[0], skiprows=[1])\n",
    "\n",
    "    # Detect new SurveyMonkey export format (one column per answer option).\n",
    "    # Old format: sub-headers say 'Response'. New format: sub-headers contain option text.\n",
    "    is_new_format = (pd.notna(row1[9]) and\n",
    "                     str(row1[9]).strip() not in ('Response', 'Open-Ended Response'))\n",
    "\n",
    "    if is_new_format:\n",
    "        col_names = list(df.columns)\n",
    "\n",
    "        # Build groups: named column position -> list of following unnamed positions\n",
    "        groups = {}\n",
    "        current = None\n",
    "        for i, h in enumerate(row0):\n",
    "            if pd.notna(h):\n",
    "                current = i\n",
    "                groups[i] = []\n",
    "            elif current is not None:\n",
    "                groups[current].append(i)\n",
    "\n",
    "        cols_to_drop = []\n",
    "        cols_to_add = {}  # new column name -> merged series\n",
    "\n",
    "        for named_idx, unnamed_idxes in sorted(groups.items()):\n",
    "            if not unnamed_idxes:\n",
    "                continue\n",
    "\n",
    "            all_idxes = [named_idx] + unnamed_idxes\n",
    "            all_names = [col_names[i] for i in all_idxes]\n",
    "            subqs = [str(row1[i]) if pd.notna(row1[i]) else '' for i in all_idxes]\n",
    "\n",
    "            if ' - ' in subqs[0]:\n",
    "                # Rating/matrix: multiple sub-questions each with multiple options.\n",
    "                # Group columns by sub-question prefix (text before ' - ').\n",
    "                by_prefix = {}\n",
    "                for idx, sq in zip(all_idxes, subqs):\n",
    "                    prefix = sq.split(' - ')[0]\n",
    "                    by_prefix.setdefault(prefix, []).append(idx)\n",
    "\n",
    "                prefixes = list(by_prefix.keys())\n",
    "\n",
    "                # First sub-question: merge options into the named column\n",
    "                first_names = [col_names[i] for i in by_prefix[prefixes[0]]]\n",
    "                df[first_names[0]] = df[first_names].bfill(axis=1).iloc[:, 0]\n",
    "                cols_to_drop.extend(first_names[1:])\n",
    "\n",
    "                # Additional sub-questions: collect under 'Unnamed: 19' for\n",
    "                # backward compatibility with rename_map -> slides_clean_simple\n",
    "                extra_keys = ['Unnamed: 19']\n",
    "                for k, prefix in enumerate(prefixes[1:]):\n",
    "                    sub_names = [col_names[i] for i in by_prefix[prefix]]\n",
    "                    new_name = extra_keys[k] if k < len(extra_keys) else f'_subq_{k + 1}'\n",
    "                    cols_to_add[new_name] = df[sub_names].bfill(axis=1).iloc[:, 0]\n",
    "                    cols_to_drop.extend(sub_names)\n",
    "            else:\n",
    "                # Single-answer MCQ: merge all option columns into the named column\n",
    "                df[all_names[0]] = df[all_names].bfill(axis=1).iloc[:, 0]\n",
    "                cols_to_drop.extend(all_names[1:])\n",
    "\n",
    "        df.drop(columns=[c for c in cols_to_drop if c in df.columns], inplace=True)\n",
    "        for new_name, series in cols_to_add.items():\n",
    "            df[new_name] = series\n",
    "\n",
    "    condition_name = os.path.splitext(os.path.basename(file_path))[0].replace(study_name+\"-\", \"\").replace(\"-\"+study_name, \"\")\n",
    "    df['condition'] = condition_name\n",
    "    df['conditionLength'] = int(condition_name.split('-')[0])\n",
    "    df['conditionType'] = condition_name.split('-')[1]\n",
    "    return df, condition_name\n",
    "\n",
    "# Function to combine headers\n",
    "def combine_headers(df):\n",
    "    df.columns = [' '.join(col).strip() for col in df.columns.values]\n",
    "    return df\n",
    "\n",
    "# Clean remaining column names\n",
    "def clean_column_names(columns):\n",
    "    cleaned_columns = []\n",
    "    for col in columns:\n",
    "        col = re.sub(r'\\bresponse\\b', '', col, flags=re.IGNORECASE)\n",
    "        col = re.sub(r'[^a-zA-Z0-9]', '_', col).lower()\n",
    "        col = col.strip('_')\n",
    "        cleaned_columns.append(col)\n",
    "    return cleaned_columns\n",
    "  \n",
    "# Function to check answers and add correctness columns\n",
    "def add_correctness_columns(df, answer_map):\n",
    "    for column, correct_answer in answer_map.items():\n",
    "        if column in df.columns:\n",
    "            df[column] = df[column].fillna(\"\")\n",
    "            # Create a new column with 1 if correct, 0 if incorrect\n",
    "            df[f'{column}_correct'] = np.where(df[column].str.strip().str.lower() == correct_answer.lower(), 1, 0)\n",
    "    return df\n",
    "\n",
    "# Function to add a total correct column for each participant\n",
    "def add_total_correct_column(df):\n",
    "    # Identify all correctness columns (columns ending with '_correct')\n",
    "    correctness_columns = [col for col in df.columns if col.endswith('_correct')]\n",
    "    # Sum the correctness columns to create the total correct column\n",
    "    df['total_correct'] = df[correctness_columns].sum(axis=1)\n",
    "    return df\n",
    "  \n",
    "# Function to merge the answers to a single question into one column\n",
    "def merge_columnes(df, column_name, number_of_columns):\n",
    "  #number_of_columns needs to be the total number, not just the ones that are to be merged\n",
    "  loc_index = df.columns.get_loc(column_name)\n",
    "  df[column_name] = df.iloc[:, loc_index:loc_index+number_of_columns].bfill(axis=1).iloc[:, 0]\n",
    "  df.drop(df.columns[loc_index+1:loc_index+number_of_columns], axis=1, inplace=True)\n",
    "  return df\n",
    "\n",
    "#function to calculate and print U-test\n",
    "def utest(cond1, cond2):\n",
    "  results = {}\n",
    "\n",
    "  for column in test_columns:\n",
    "    df_combined_dropna = df_combined.dropna(subset = [column], inplace=False)\n",
    "    U1, p = stats.mannwhitneyu(df_combined_dropna[column][df_combined_dropna['condition'] == cond1],\n",
    "                df_combined_dropna[column][df_combined_dropna['condition'] == cond2], method=\"exact\")\n",
    "    results[column] = {'U1_stat': U1, 'p_value': p}\n",
    "  \n",
    "  df = pd.DataFrame.from_dict(results, orient = \"index\")\n",
    "  df.index = test_column_names\n",
    "  Markdown(tabulate(df, headers = [\"U1 statistic\", \"p-value\"]))\n",
    "\n",
    "  display(Markdown(df.to_markdown()))"
   ]
